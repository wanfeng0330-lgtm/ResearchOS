PORT=3001

# DeepSeek API (Required - used for keyword extraction, literature analysis, outline generation)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Token Plan / Mimo API (Required - used for viewpoint extraction and paper writing)
TOKEN_PLAN_API_KEY=your_token_plan_api_key_here
TOKEN_PLAN_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# SiliconFlow API (Optional - used for chart image generation)
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# Image Generation API Key (Optional - used for chart image generation)
IMAGE_API_KEY=your_image_api_key_here

# Database (Optional - falls back to in-memory storage if not configured)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/researchos

# Redis (Optional - used for caching)
REDIS_URL=redis://localhost:6379

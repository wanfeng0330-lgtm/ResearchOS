PORT=3001

# JWT Secret (Required for authentication - change in production)
JWT_SECRET=your_jwt_secret_here_change_in_production

# DeepSeek API (Required - used for keyword extraction, literature analysis, outline generation)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Token Plan / Mimo API (Required - used for viewpoint extraction and paper writing)
TOKEN_PLAN_API_KEY=your_token_plan_api_key_here
TOKEN_PLAN_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# SiliconFlow API (Optional - used for chart image generation)
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# Semantic Scholar API Key (Optional - increases rate limit from 100 to 1000 per 5 min)
# Get one at: https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=

# PubMed API Key (Optional - increases rate limit from 3 to 10 requests/sec)
# Get one at: https://www.ncbi.nlm.nih.gov/account/settings/
PUBMED_API_KEY=

# Unpaywall Email (Required for Unpaywall API - used for open access PDF lookup)
UNPAYWALL_EMAIL=your_email@example.com

# Image Generation API Key (Optional - used for chart image generation)
IMAGE_API_KEY=your_image_api_key_here

# Database (Optional - falls back to in-memory storage if not configured)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/researchos

# Redis (Optional - used for caching)
REDIS_URL=redis://localhost:6379

# Frontend URL (Used for CORS origin whitelist)
FRONTEND_URL=http://localhost:5173

# Node environment (development | production)
NODE_ENV=development
